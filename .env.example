# =============================================================================
# IntelliDesk Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Environment variables take precedence over values in .env files.
# =============================================================================

# --- Application Profile ---
# Activates the environment profile: local, dev, prod
APP_PROFILE=local

# --- Server ---
SERVER_PORT=8080

# --- LLM Service ---
# Groq API key (required for LLM calls)
GROQ_API_KEY=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
# LLM base URL (Groq uses OpenAI-compatible format)
LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM model to use for answer generation
LLM_MODEL=llama-3.3-70b-versatile
# Timeout in seconds for LLM calls
LLM_TIMEOUT_SECONDS=30
# OpenAI API key (legacy, not needed when using Groq)
OPENAI_API_KEY=sk-not-used

# --- Embedding Model ---
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector Store ---
# URL of the vector store (ChromaDB for local, Pinecone for prod)
VECTOR_STORE_URL=http://localhost:8000

# --- Speech-to-Text Service ---
# STT is now handled in-browser via Web Speech API.
# The STT_SERVICE_URL is kept for the health check but is not actively used.
STT_SERVICE_URL=http://localhost:9000

# --- RAG Pipeline ---
# Number of top chunks to retrieve
RAG_TOP_K=5
# Minimum similarity score for retrieved chunks (0.0 - 1.0)
RAG_SIMILARITY_THRESHOLD=0.7
# Chunk size in tokens (64 - 2048)
RAG_CHUNK_SIZE=512
# Overlap between chunks in tokens (0 - 50% of chunk size)
RAG_CHUNK_OVERLAP=50
# Path to the knowledge base directory
KNOWLEDGE_BASE_DIR=./data/knowledge-base

# --- Session Management ---
# Number of recent exchanges to keep in context (1 - 50)
SESSION_CONTEXT_WINDOW=10
# Session timeout in minutes (1 - 1440)
SESSION_TIMEOUT_MINUTES=30

# --- Security ---
# Max requests per session per minute
RATE_LIMIT_PER_MINUTE=20
# Max message length in characters
MAX_MESSAGE_LENGTH=4000
# Max audio file size in MB
MAX_AUDIO_SIZE_MB=10
# Max audio duration in seconds
MAX_AUDIO_DURATION_SEC=60
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Evaluation ---
# Path to evaluation dataset JSON file
EVALUATION_DATASET_PATH=./data/evaluation/dataset.json
# Path where evaluation reports are written
EVALUATION_REPORT_PATH=./data/evaluation/report.json
# Minimum threshold for metrics to pass (0.0 - 1.0)
EVALUATION_THRESHOLD=0.7
# Evaluation timeout in seconds
EVALUATION_TIMEOUT_SECONDS=120

# --- Circuit Breaker ---
# Number of consecutive failures before opening circuit
CB_FAILURE_THRESHOLD=5
# Cooldown period in seconds before transitioning to half-open
CB_COOLDOWN_SECONDS=30

# --- Health Check ---
# Timeout in seconds for individual dependency health checks (1 - 30)
HEALTH_CHECK_TIMEOUT_SECONDS=5

# --- Workflow ---
# Timeout in seconds for individual workflow nodes
WORKFLOW_NODE_TIMEOUT_SECONDS=30
